{
  "name": "@unigent/workspace",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "bin": {
    "unigent": "./scripts/unigent-dev.mjs"
  },
  "description": "Coordinate Pi, Claude CLI, and Codex CLI in one typed TypeScript workflow.",
  "keywords": [
    "agents",
    "llm",
    "ai",
    "orchestration",
    "coordination",
    "agent-framework",
    "typescript"
  ],
  "license": "MIT",
  "author": "Gintas Zenevskis",
  "homepage": "https://github.com/gintasz/unigent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gintasz/unigent.git"
  },
  "bugs": "https://github.com/gintasz/unigent/issues",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ],
    "overrides": {
      "brace-expansion": ">=5.0.7",
      "fast-uri": ">=3.1.4",
      "linkify-it": "~5.0.2"
    }
  },
  "scripts": {
    "build": "tsc -b && corepack pnpm --filter unigent-sdk run build:bundle && corepack pnpm --filter unigent-cli run build:bundle",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.test.json --pretty false && tsc -p tsconfig.examples.json --pretty false",
    "test": "tsc -b && vitest run --exclude '**/e2e.test.ts'",
    "coverage": "vitest run --coverage --exclude '**/e2e.test.ts' --maxWorkers=4 --testTimeout=30000",
    "test:tui": "vitest run packages/unigent-cli/test/e2e.test.ts",
    "test:e2e": "corepack pnpm --filter @unigent/e2e run test:e2e",
    "format:check": "biome format .",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "lint:types": "eslint packages",
    "arch": "depcruise packages --config .dependency-cruiser.cjs",
    "ast": "ast-grep scan",
    "spell": "typos",
    "deps:check": "syncpack lint",
    "audit": "node scripts/audit-dependencies.mjs",
    "check:docker": "scripts/ci-docker.sh",
    "dead": "knip",
    "dup": "jscpd packages",
    "api": "corepack pnpm -r --if-present run api",
    "api:check": "corepack pnpm -r --if-present run api:check",
    "docs:check": "typedoc --emit none --treatWarningsAsErrors --tsconfig packages/unigent/tsconfig.json --validation.invalidLink --validation.notExported packages/unigent/src/index.ts packages/unigent/src/trace.ts packages/unigent/src/tools.ts packages/unigent/src/args.ts packages/unigent/src/mcp.ts packages/unigent/src/test.ts",
    "package:check": "node scripts/check-package-contract.mjs",
    "cli": "node --import tsx packages/unigent-cli/src/cli.ts",
    "sync-docs": "node scripts/sync-package-docs.mjs",
    "release": "node scripts/release.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "link": "corepack pnpm link",
    "unlink": "corepack pnpm uninstall --global @unigent/workspace",
    "check": "turbo run //#typecheck //#format:check //#lint //#lint:types //#ast --continue --output-logs=errors-only --log-order=grouped --log-prefix=none",
    "check:full": "turbo run //#build //#typecheck //#format:check //#lint //#lint:types //#arch //#ast //#spell //#deps:check //#audit //#dead //#dup //#docs:check //#package:check //#coverage api:check --continue --output-logs=errors-only --log-order=grouped --log-prefix=none",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@ast-grep/cli": "0.44.0",
    "@biomejs/biome": "2.5.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@unigent/test": "workspace:*",
    "@microsoft/api-extractor": "7.58.9",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.20",
    "dependency-cruiser": "18.0.0",
    "eslint": "10.6.0",
    "eslint-plugin-tsdoc": "0.5.2",
    "fast-check": "4.8.0",
    "jscpd": "5.0.11",
    "knip": "6.21.0",
    "lefthook": "2.1.9",
    "publint": "0.3.21",
    "unigent-sdk": "workspace:*",
    "syncpack": "15.3.2",
    "tsx": "4.22.4",
    "turbo": "2.10.1",
    "typedoc": "0.28.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.8",
    "zod": "4.4.3"
  }
}
