{
  "name": "microfoom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A TypeScript framework for agentic coordination: compose many agents, sessions, and model harnesses into one typed program.",
  "keywords": [
    "agents",
    "llm",
    "ai",
    "orchestration",
    "coordination",
    "agent-framework",
    "typescript"
  ],
  "license": "MIT",
  "author": "Gintas Zenevskis <gintas.zenevskis@gmail.com>",
  "homepage": "https://gintasz.github.io/microfoom/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gintasz/microfoom.git"
  },
  "bugs": "https://github.com/gintasz/microfoom/issues",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.test.json --pretty false",
    "test": "vitest run --exclude '**/e2e.test.ts'",
    "coverage": "vitest run --coverage --exclude '**/e2e.test.ts'",
    "test:e2e": "vitest run e2e.test",
    "format:check": "biome format .",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "lint:types": "eslint .",
    "arch": "depcruise packages --config .dependency-cruiser.cjs",
    "ast": "ast-grep scan",
    "spell": "typos",
    "deps:check": "syncpack lint",
    "audit": "corepack pnpm audit --audit-level=high",
    "check:docker": "scripts/ci-docker.sh",
    "dead": "knip",
    "dup": "jscpd packages",
    "api": "corepack pnpm -r --if-present run api",
    "api:check": "corepack pnpm -r --if-present run api:check",
    "docs:check": "typedoc --emit none --treatWarningsAsErrors --tsconfig packages/microfoom-core/tsconfig.json --validation.invalidLink --validation.notExported packages/microfoom-core/src/index.ts packages/microfoom-core/src/trace/index.ts",
    "cli": "node --import tsx packages/microfoom-cli/src/cli.ts",
    "sync-docs": "node scripts/sync-package-docs.mjs",
    "release": "corepack pnpm run build && node scripts/sync-package-docs.mjs && corepack pnpm -r publish --access public --no-git-checks && node scripts/sync-package-docs.mjs --clean",
    "link": "corepack pnpm run build && corepack pnpm config set global-bin-dir \"$(npm prefix -g)/bin\" && cd packages/microfoom-cli && corepack pnpm link --global",
    "unlink": "cd packages/microfoom-cli && corepack pnpm unlink --global",
    "check": "turbo run //#typecheck //#format:check //#lint //#lint:types //#ast --continue --output-logs=errors-only --log-order=grouped --log-prefix=none",
    "check:full": "turbo run //#build //#typecheck //#format:check //#lint //#lint:types //#arch //#ast //#spell //#deps:check //#audit //#dead //#dup //#docs:check //#coverage api:check --continue --output-logs=errors-only --log-order=grouped --log-prefix=none",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@ast-grep/cli": "0.44.0",
    "@biomejs/biome": "2.5.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@microfoom/core": "workspace:*",
    "@microfoom/pi-adapter": "workspace:*",
    "@microsoft/api-extractor": "7.58.9",
    "@swc/core": "1.15.43",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.20",
    "dependency-cruiser": "18.0.0",
    "eslint": "10.6.0",
    "eslint-plugin-tsdoc": "0.5.2",
    "fast-check": "4.8.0",
    "jscpd": "5.0.11",
    "knip": "6.21.0",
    "lefthook": "2.1.9",
    "syncpack": "15.3.2",
    "tsx": "4.22.4",
    "turbo": "2.10.1",
    "typedoc": "0.28.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.8",
    "zod": "4.4.3"
  }
}
