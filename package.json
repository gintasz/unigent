{
  "name": "microfoom",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --exclude '**/e2e.test.ts'",
    "test:e2e": "vitest run e2e.test",
    "test:all": "vitest run",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "arch": "depcruise packages --config .dependency-cruiser.cjs",
    "ast": "ast-grep scan",
    "spell": "cspell --no-progress \"**/*.{ts,tsx,md,json}\"",
    "deps:check": "syncpack lint",
    "deps:fix": "syncpack fix",
    "dead": "knip",
    "dup": "jscpd packages",
    "api": "pnpm -r --if-present run api",
    "api:check": "pnpm -r --if-present run api:check",
    "docs:check": "typedoc --emit none --treatWarningsAsErrors --tsconfig packages/microfoom-core/tsconfig.json --validation.invalidLink --validation.notExported packages/microfoom-core/src/index.ts packages/microfoom-core/src/trace/index.ts",
    "example": "node --import tsx examples/run.ts examples/hello.ts world",
    "cli": "node --import tsx packages/microfoom-cli/src/cli.ts",
    "link": "pnpm run build && pnpm config set global-bin-dir \"$(npm prefix -g)/bin\" && cd packages/microfoom-cli && pnpm link --global",
    "unlink": "cd packages/microfoom-cli && pnpm unlink --global",
    "check": "pnpm run typecheck && pnpm run format:check && pnpm run lint && pnpm run arch && pnpm run ast && pnpm run spell && pnpm run deps:check && pnpm run dead && pnpm run dup && pnpm run build && pnpm run api:check && pnpm run docs:check && pnpm run test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@ast-grep/cli": "0.44.0",
    "@biomejs/biome": "2.5.1",
    "@microfoom/core": "workspace:*",
    "@microfoom/pi-adapter": "workspace:*",
    "@microsoft/api-extractor": "7.58.9",
    "@swc/core": "1.15.43",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "24.13.2",
    "cspell": "10.0.1",
    "dependency-cruiser": "18.0.0",
    "fast-check": "4.8.0",
    "jscpd": "5.0.11",
    "knip": "6.21.0",
    "lefthook": "2.1.9",
    "syncpack": "15.3.2",
    "tsx": "4.22.4",
    "typedoc": "0.28.19",
    "typescript": "5.9.3",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.8",
    "zod": "4.4.3"
  }
}
