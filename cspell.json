{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "useGitignore": true,
  "dictionaryDefinitions": [
    { "name": "project-words", "path": "./project-words.txt", "addWords": true }
  ],
  "dictionaries": ["project-words"],
  "ignorePaths": [
    "node_modules/**",
    "**/dist/**",
    "coverage/**",
    "pnpm-lock.yaml",
    "**/*.api.md",
    "etc/**",
    "docs/design/**",
    "docs/audit/**",
    "docs-website/**"
  ]
}
