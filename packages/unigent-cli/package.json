  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/assert-package-docs.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentui/core": "0.4.2",
    "@opentui/react": "0.4.2",
    "@standard-schema/spec": "1.1.0",
    "@unigent/core": "workspace:*",
    "ajv": "8.17.1",
    "react": "19.2.0",
    "react-devtools-core": "7.0.1",
    "web-tree-sitter": "0.25.10",
    "ws": "8.21.0"
  },
  "bundledDependencies": [
    "@unigent/core"
  ],
  "devDependencies": {
    "@termless/core": "0.7.0",
    "@termless/xtermjs": "0.4.0",
    "@types/react": "19.2.2"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
