{
  "name": "@unigent/cli",
  "version": "0.1.1",
  "type": "module",
  "description": "Node.js script runner and Bun-powered live trace inspector for Unigent",
  "keywords": [
    "agents",
    "llm",
    "ai",
    "orchestration",
    "cli",
    "tui",
    "typescript"
  ],
  "license": "MIT",
  "author": "Gintas Zenevskis",
  "homepage": "https://github.com/gintasz/unigent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gintasz/unigent.git",
    "directory": "packages/unigent-cli"
  },
  "bugs": "https://github.com/gintasz/unigent/issues",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
