{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": ".tsbuildinfo",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "inlineSources": true,
    "resolveJsonModule": true,
    "types": ["node", "react"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [{ "path": "../unigent-core" }]
}
