{
  "name": "@microfoom/pi-adapter",
  "version": "0.1.0",
  "type": "module",
  "description": "Microfoom harness adapter for the Pi agent SDK",
  "keywords": [
    "microfoom",
    "agents",
    "llm",
    "harness",
    "pi-agent",
    "typescript"
  ],
  "license": "MIT",
  "author": "Gintas Zenevskis <gintas.zenevskis@gmail.com>",
  "homepage": "https://gintasz.github.io/microfoom/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gintasz/microfoom.git",
    "directory": "packages/pi-adapter"
  },
  "bugs": "https://github.com/gintasz/microfoom/issues",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "api": "api-extractor run --local --verbose",
    "api:check": "api-extractor run --verbose"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.2",
    "@earendil-works/pi-ai": "0.80.2",
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@microfoom/core": "workspace:*",
    "typebox": "1.1.38"
  }
}
