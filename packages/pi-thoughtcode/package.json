{
  "name": "pi-thoughtcode",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "thoughtcode"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "thoughtcode-core": "0.0.0",
    "typebox": "1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.79.9 <0.80.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.79.9"
  }
}
