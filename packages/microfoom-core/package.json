{
  "name": "@microfoom/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core of the microfoom framework: the agent runtime + typed building blocks for coordinating many agents across model harnesses from durable TypeScript.",
  "keywords": [
    "agents",
    "llm",
    "ai",
    "orchestration",
    "coordination",
    "agent-framework",
    "typescript"
  ],
  "license": "MIT",
  "author": "Gintas Zenevskis <gintas.zenevskis@gmail.com>",
  "homepage": "https://gintasz.github.io/microfoom/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gintasz/microfoom.git",
    "directory": "packages/microfoom-core"
  },
  "bugs": "https://github.com/gintasz/microfoom/issues",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./trace": {
      "types": "./dist/trace/index.d.ts",
      "default": "./dist/trace/index.js"
    }
  },
  "scripts": {
    "api": "api-extractor run --local --verbose",
    "api:check": "api-extractor run --verbose"
  },
  "dependencies": {
    "@standard-schema/spec": "1.1.0",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "0.6.1"
  }
}
