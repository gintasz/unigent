{
  "name": "@microfoom/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI + TUI runner for microfoom coordination programs.",
  "keywords": [
    "microfoom",
    "agents",
    "llm",
    "cli",
    "tui",
    "orchestration",
    "typescript"
  ],
  "license": "MIT",
  "author": "Gintas Zenevskis <gintas.zenevskis@gmail.com>",
  "homepage": "https://gintasz.github.io/microfoom/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gintasz/microfoom.git",
    "directory": "packages/microfoom-cli"
  },
  "bugs": "https://github.com/gintasz/microfoom/issues",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "microfoom": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "api": "api-extractor run --local --verbose",
    "api:check": "api-extractor run --verbose"
  },
  "dependencies": {
    "@microfoom/claudecli-adapter": "workspace:*",
    "@microfoom/core": "workspace:*",
    "@microfoom/pi-adapter": "workspace:*",
    "@opentui/core": "0.4.2",
    "@opentui/react": "0.4.2",
    "cli-truncate": "4.0.0",
    "log-update": "6.1.0",
    "picocolors": "1.1.1",
    "react": "19.2.0",
    "string-width": "7.2.0",
    "tsx": "4.22.4"
  },
  "devDependencies": {
    "@termless/core": "0.7.0",
    "@termless/xtermjs": "0.4.0",
    "@types/react": "19.2.2",
    "node-pty": "1.1.0",
    "silvery": "0.21.0"
  }
}
