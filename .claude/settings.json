{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/worktree-bootstrap.sh",
            "timeout": 600,
            "statusMessage": "Bootstrapping worktree…"
          }
        ]
      }
    ]
  }
}
